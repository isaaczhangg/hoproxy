{
  "name": "hopgpt-anthropic-proxy",
  "version": "1.0.0",
  "description": "Anthropic-compatible API proxy for HopGPT",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "hopgpt-anthropic-proxy": "src/index.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "extract": "node src/extract-credentials.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "eventsource-parser": "^1.1.1",
    "express": "^4.18.2",
    "node-tls-client": "^2.1.0",
    "puppeteer": "^24.34.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
